# Server
PORT=4000
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_ALLOW_CREDENTIALS=false
MORGAN_FORMAT=combined

# Database (Postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skillbridge
POSTGRES_USER=skillbridge_user
POSTGRES_PASSWORD=skillbridge_password
DATABASE_URL=postgresql://skillbridge_user:skillbridge_password@localhost:5432/skillbridge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
JWT_ISSUER=skillbridge

# Razorpay
RAZORPAY_KEY_ID=replace_with_key_id
RAZORPAY_KEY_SECRET=replace_with_key_secret

# Starter data (non-secret) for the sample skills endpoint
SKILLS_SAMPLE_JSON=[{"id":"skill_1","title":"UI/UX Design","category":"design","hourlyRate":{"amount":7500,"currency":"USD"},"rating":4.8,"verified":true},{"id":"skill_2","title":"Frontend Engineering","category":"development","hourlyRate":{"amount":9000,"currency":"USD"},"rating":4.7,"verified":true},{"id":"skill_3","title":"Conversion Copywriting","category":"writing","hourlyRate":{"amount":6200,"currency":"USD"},"rating":4.6,"verified":false}]

