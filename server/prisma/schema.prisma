generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  FREELANCER
  ADMIN
}

enum JobType {
  FREE
  BID
  ADMIN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TransactionType {
  CREDIT_PURCHASE
  CREDIT_EARNED
  CREDIT_SPENT
  PLATFORM_FEE
  PAYOUT
  REFUND
}

enum AdminJobStatus {
  AVAILABLE
  CLAIMED
  SUBMITTED
  APPROVED
  REJECTED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String
  fullName      String
  avatarUrl     String?
  role          UserRole
  creditBalance Float    @default(50)
  rating        Float?
  totalRatings  Float    @default(0)
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  freelancerProfile      FreelancerProfile?
  clientJobs             Job[]         @relation("JobClient")
  assignedFreelancerJobs Job[]         @relation("JobAssignedFreelancer")
  adminJobs              Job[]         @relation("JobAdmin")
  bids                   Bid[]         @relation("BidFreelancer")
  transactions           Transaction[] @relation("TransactionUser")
  reviewsAsReviewer      Review[]      @relation("ReviewReviewer")
  reviewsAsReviewee      Review[]      @relation("ReviewReviewee")
  assignedAdminJobs      AdminJob[]    @relation("AdminJobAssignedTo")
  notifications          Notification[] @relation("NotificationUser")
  sentMessages           Message[]      @relation("MessageSender")
  receivedMessages       Message[]      @relation("MessageReceiver")
  aiFlags                AiFlag[]
  clientEscrows          Escrow[]       @relation("EscrowClient")
  freelancerEscrows      Escrow[]       @relation("EscrowFreelancer")
  skillTestAttempts      SkillTestAttempt[]
  skillBadges            SkillBadge[]
  services               Service[]      @relation("FreelancerServices")
  clientServiceOrders    ServiceOrder[] @relation("ClientServiceOrders")
  freelancerServiceOrders ServiceOrder[] @relation("FreelancerServiceOrders")

  @@map("users")
}

model FreelancerProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @db.Uuid
  bio                String
  skills             String[]
  hourlyRate         Float?
  portfolioUrl       String?
  skillPassportScore Float    @default(0)
  completedJobs      Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("freelancer_profiles")
}

model Job {
  id                   String    @id @default(uuid()) @db.Uuid
  title                String
  description          String
  type                 JobType
  status               JobStatus
  budget               Float?
  clientId             String    @db.Uuid
  assignedFreelancerId String?   @db.Uuid
  adminId              String?   @db.Uuid
  creditReward         Int?
  platformFeePercent   Int       @default(10)
  deadlineAt           DateTime?
  category             String?   @default("General")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  client             User      @relation("JobClient", fields: [clientId], references: [id])
  assignedFreelancer User?     @relation("JobAssignedFreelancer", fields: [assignedFreelancerId], references: [id])
  admin              User?     @relation("JobAdmin", fields: [adminId], references: [id])
  bids               Bid[]     @relation("BidJob")
  reviews            Review[]  @relation("ReviewJob")
  adminJob           AdminJob? @relation("JobAdminJob")
  messages           Message[]
  escrow             Escrow?

  @@index([clientId])
  @@index([assignedFreelancerId])
  @@index([adminId])
  @@index([status])
  @@map("jobs")
}

model Bid {
  id           String    @id @default(uuid()) @db.Uuid
  jobId        String    @db.Uuid
  freelancerId String    @db.Uuid
  amount       Float
  coverLetter  String
  status       BidStatus
  creditsSpent Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  job        Job  @relation("BidJob", fields: [jobId], references: [id])
  freelancer User @relation("BidFreelancer", fields: [freelancerId], references: [id])

  @@index([jobId])
  @@index([freelancerId])
  @@index([status])
  @@map("bids")
}

model Escrow {
  id           String       @id @default(uuid()) @db.Uuid
  jobId        String       @unique @db.Uuid
  clientId     String       @db.Uuid
  freelancerId String       @db.Uuid
  amount       Float
  platformFee  Float
  netAmount    Float
  status       EscrowStatus @default(HELD)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  job        Job  @relation(fields: [jobId], references: [id])
  client     User @relation("EscrowClient", fields: [clientId], references: [id])
  freelancer User @relation("EscrowFreelancer", fields: [freelancerId], references: [id])

  @@index([jobId])
  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@map("escrows")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  userId      String          @db.Uuid
  type        TransactionType
  amount      Float
  credits     Int?
  description String
  referenceId String?
  createdAt   DateTime        @default(now())

  user User @relation("TransactionUser", fields: [userId], references: [id])

  @@index([userId])
  @@map("transactions")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  jobId      String   @db.Uuid
  reviewerId String   @db.Uuid
  revieweeId String   @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  job      Job  @relation("ReviewJob", fields: [jobId], references: [id])
  reviewer User @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  reviewee User @relation("ReviewReviewee", fields: [revieweeId], references: [id])

  @@index([jobId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model AdminJob {
  id           String         @id @default(uuid()) @db.Uuid
  jobId        String         @unique @db.Uuid
  assignedTo   String?        @db.Uuid
  creditReward Int
  status       AdminJobStatus
  submissionUrl String?
  reviewNote   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  job          Job   @relation("JobAdminJob", fields: [jobId], references: [id])
  assignedUser User? @relation("AdminJobAssignedTo", fields: [assignedTo], references: [id])

  @@index([jobId])
  @@index([status])
  @@index([assignedTo])
  @@map("admin_jobs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("NotificationUser", fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model Message {
  id          String   @id @default(uuid()) @db.Uuid
  senderId    String   @db.Uuid
  receiverId  String   @db.Uuid
  jobId       String?  @db.Uuid
  content     String
  isBlocked   Boolean  @default(false)
  flagReason  String?
  createdAt   DateTime @default(now())

  sender   User  @relation("MessageSender", fields: [senderId], references: [id])
  receiver User  @relation("MessageReceiver", fields: [receiverId], references: [id])
  job      Job?  @relation(fields: [jobId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([jobId])
  @@map("messages")
}

model AiFlag {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  messageId  String?  @db.Uuid
  reason     String
  severity   String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resolved])
  @@map("ai_flags")
}

model SkillTest {
  id          String   @id @default(uuid()) @db.Uuid
  skill       String   // e.g. "React", "Python", "UI Design"
  title       String
  description String
  passMark    Int      @default(70) // percentage
  createdAt   DateTime @default(now())

  questions   SkillTestQuestion[]
  attempts    SkillTestAttempt[]

  @@map("skill_tests")
}

model SkillTestQuestion {
  id          String   @id @default(uuid()) @db.Uuid
  testId      String   @db.Uuid
  question    String
  options     Json     // string[] of 4 options
  correctIdx  Int      // 0-3 index of correct answer — NEVER sent to frontend
  createdAt   DateTime @default(now())

  test SkillTest @relation(fields: [testId], references: [id])

  @@map("skill_test_questions")
}

model SkillTestAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  testId    String   @db.Uuid
  score     Int      // percentage 0-100
  passed    Boolean
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  test SkillTest @relation(fields: [testId], references: [id])

  @@unique([userId, testId])  // one attempt per user per test
  @@map("skill_test_attempts")
}

model SkillBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  skill     String
  testId    String   @db.Uuid
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, skill])
  @@map("skill_badges")
}

// ─── Services (Gig) System ───────────────────────────────────────

enum ServiceOrderStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  REVISION_REQUESTED
  COMPLETED
  CANCELLED
}

model Service {
  id           String   @id @default(uuid()) @db.Uuid
  freelancerId String   @db.Uuid
  title        String
  description  String
  category     String
  subcategory  String?
  price        Float
  deliveryDays Int
  revisions    Int      @default(1)
  includes     Json     // string[] of 3 bullet points
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  freelancer User           @relation("FreelancerServices", fields: [freelancerId], references: [id])
  orders     ServiceOrder[]

  @@index([freelancerId])
  @@index([category])
  @@index([isActive])
  @@map("services")
}

model ServiceOrder {
  id           String             @id @default(uuid()) @db.Uuid
  serviceId    String             @db.Uuid
  clientId     String             @db.Uuid
  freelancerId String             @db.Uuid
  price        Float
  status       ServiceOrderStatus @default(PENDING)
  requirements String?
  deliverable  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  service    Service @relation(fields: [serviceId], references: [id])
  client     User    @relation("ClientServiceOrders", fields: [clientId], references: [id])
  freelancer User    @relation("FreelancerServiceOrders", fields: [freelancerId], references: [id])

  @@index([serviceId])
  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@map("service_orders")
}
